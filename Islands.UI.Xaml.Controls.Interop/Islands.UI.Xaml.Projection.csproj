<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.18362.0</TargetPlatformMinVersion>
    <AssemblyName>Islands.UI.Xaml.Projection</AssemblyName>
    <RootNamespace>Islands.UI.Xaml</RootNamespace>
    <UseUwp>true</UseUwp>
    <Platforms>x86;x64;arm64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <DefaultLanguage>zh-CN</DefaultLanguage>
    <ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>None</ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>
    <SolutionDir Condition="'$(SolutionDir)' == '' Or '$(SolutionDir)' == '*Undefined*'">$(MSBuildThisFileDirectory)..\</SolutionDir>
    <IslandsNativePlatform Condition="'$(Platform)' == 'x86'">Win32</IslandsNativePlatform>
    <IslandsNativePlatform Condition="'$(IslandsNativePlatform)' == ''">$(Platform)</IslandsNativePlatform>
    <IslandsOutPlatform>$(Platform)</IslandsOutPlatform>
  </PropertyGroup>

  <PropertyGroup>
    <CsWinRTIncludes>Islands.UI.Xaml.Controls</CsWinRTIncludes>
  </PropertyGroup>

  <ItemGroup>
    <CsWinRTInputs Include="$(SolutionDir)bin\$(IslandsNativePlatform)\$(Configuration)\Islands.UI.Xaml.winmd" />
    <CsWinRTInputs Include="$(PkgMicrosoft_UI_Xaml)\lib\uap10.0\Microsoft.UI.Xaml.winmd" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.2.0" />
    <PackageReference Include="Microsoft.UI.Xaml" Version="2.8.7" GeneratePathProperty="true" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Islands.UI.Xaml.Controls\Islands.UI.Xaml.vcxproj"
                      PrivateAssets="all"
                      ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true">
      <SetConfiguration>Configuration=$(Configuration);SolutionDir=$(SolutionDir)</SetConfiguration>
      <SetPlatform>Platform=$(IslandsNativePlatform)</SetPlatform>
    </ProjectReference>
  </ItemGroup>

  <Target Name="CopyIslandsInteropOutputs" AfterTargets="Build">
    <PropertyGroup>
      <IslandsNativeOutputDir>$(SolutionDir)bin\$(IslandsNativePlatform)\$(Configuration)\</IslandsNativeOutputDir>
      <IslandsOutDir>$(MSBuildProjectDirectory)\out\$(IslandsOutPlatform)\</IslandsOutDir>
    </PropertyGroup>

    <ItemGroup>
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.dll" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.exp" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.lib" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.pdb" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.pri" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.winmd" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Islands.UI.Xaml.Automation.winmd" />
      <IslandsNativeOutput Include="$(IslandsNativeOutputDir)Microsoft.UI.Xaml.dll" />
      <IslandsProjectionOutput Include="$(TargetDir)Islands.UI.Xaml.Projection.*" />
    </ItemGroup>

    <RemoveDir Directories="$(IslandsOutDir)" />
    <MakeDir Directories="$(IslandsOutDir)native;$(IslandsOutDir)projection" />
    <Copy SourceFiles="@(IslandsNativeOutput)"
          DestinationFolder="$(IslandsOutDir)native"
          SkipUnchangedFiles="false" />
    <Copy SourceFiles="@(IslandsProjectionOutput)"
          DestinationFolder="$(IslandsOutDir)projection"
          SkipUnchangedFiles="false" />
  </Target>
</Project>
