<Page
    x:Class="IUXControlsTestApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Islands.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:TitleBar
            x:Name="WindowingTitleBar"
            Grid.Row="0"
            AutoRefreshDragRegions="True"
            IsBackButtonEnabled="True"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="True"
            BackRequested="WindowingTitleBar_BackRequested"
            Title="IUX Controls Test App">
            <controls:TitleBar.IconSource>
                <muxc:SymbolIconSource Symbol="Home" />
            </controls:TitleBar.IconSource>
        </controls:TitleBar>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Margin="24,16,24,0"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="TitleBarSampleButton"
                    Click="TitleBarSampleButton_Click"
                    Content="TitleBar" />
                <Button
                    x:Name="ScrollViewSampleButton"
                    Click="ScrollViewSampleButton_Click"
                    Content="ScrollView" />
                <Button
                    x:Name="ScrollPresenterSampleButton"
                    Click="ScrollPresenterSampleButton_Click"
                    Content="ScrollPresenter" />
            </StackPanel>

            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Page>
