<UserControl
    x:Class="IUXControlsTestApp.ScrollViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Islands.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                Click="AddRowButton_Click"
                Content="Add row" />
            <Button
                Click="ToggleWidthButton_Click"
                Content="Toggle width" />
            <Button
                Click="ScrollToOriginButton_Click"
                Content="Origin" />
            <TextBlock
                x:Name="MetricsTextBlock"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                Text="H 0  V 0" />
        </StackPanel>

        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1">
            <controls:ScrollView
                x:Name="SampleScrollView"
                ContentOrientation="Both"
                HorizontalScrollBarVisibility="Visible"
                HorizontalScrollMode="Enabled"
                VerticalScrollBarVisibility="Visible"
                VerticalScrollMode="Enabled"
                ViewChanged="SampleScrollView_ViewChanged">
                <Grid
                    x:Name="ScrollableContent"
                    Width="1280"
                    Height="900"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="24" Spacing="10">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="ScrollView" />
                        <TextBlock Text="Wide and tall content" />
                    </StackPanel>

                    <StackPanel
                        x:Name="RowsPanel"
                        Grid.Row="1"
                        Margin="24,0,24,24"
                        Spacing="12">
                        <Border
                            Height="96"
                            Background="#FFD7E8FF"
                            BorderBrush="#FF5B78A0"
                            BorderThickness="1">
                            <TextBlock
                                Margin="16"
                                VerticalAlignment="Center"
                                FontSize="18"
                                Text="Row 1" />
                        </Border>
                        <Border
                            Height="96"
                            Background="#FFFFE3C2"
                            BorderBrush="#FFA56A2A"
                            BorderThickness="1">
                            <TextBlock
                                Margin="16"
                                VerticalAlignment="Center"
                                FontSize="18"
                                Text="Row 2" />
                        </Border>
                        <Border
                            Height="96"
                            Background="#FFD9F0D3"
                            BorderBrush="#FF5D8B56"
                            BorderThickness="1">
                            <TextBlock
                                Margin="16"
                                VerticalAlignment="Center"
                                FontSize="18"
                                Text="Row 3" />
                        </Border>
                    </StackPanel>
                </Grid>
            </controls:ScrollView>
        </Border>
    </Grid>
</UserControl>
