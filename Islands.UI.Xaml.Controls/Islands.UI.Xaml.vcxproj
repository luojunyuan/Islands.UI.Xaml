  <Target Name="CleanCppWinRTFilteredModuleInterfaces" Condition="'$(CppWinRTBuildModule)' == 'true' And ('$(CppWinRTModuleInclude)' != '' Or '$(CppWinRTModuleExclude)' != '')">
    <PropertyGroup>
      <_CppWinRTModuleFilterCache>$(IntDir)$(MSBuildProjectFile).cppwinrt_modules.cache</_CppWinRTModuleFilterCache>
      <_CppWinRTModuleFilterValue>$(CppWinRTModuleInclude)|$(CppWinRTModuleExclude)</_CppWinRTModuleFilterValue>
      <_CppWinRTPreviousModuleFilterValue Condition="Exists('$(_CppWinRTModuleFilterCache)')">$([System.IO.File]::ReadAllText('$(_CppWinRTModuleFilterCache)'))</_CppWinRTPreviousModuleFilterValue>
    </PropertyGroup>
    <ItemGroup Condition="'$(_CppWinRTPreviousModuleFilterValue)' != '$(_CppWinRTModuleFilterValue)'">
      <_StaleCppWinRTModuleInterface Include="$(GeneratedFilesDir)winrt\*.ixx" />
      <_StaleCppWinRTProjectionResponse Include="$(CppWinRTPlatformProjectionResponseFile)" />
      <_StaleCppWinRTProjectionResponse Include="$(CppWinRTReferenceProjectionResponseFile)" />
      <_StaleCppWinRTProjectionResponse Include="$(CppWinRTComponentProjectionResponseFile)" />
    </ItemGroup>
    <Delete Files="@(_StaleCppWinRTModuleInterface);@(_StaleCppWinRTProjectionResponse)" />
    <WriteLinesToFile File="$(_CppWinRTModuleFilterCache)" Lines="$(_CppWinRTModuleFilterValue)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <FileWrites Include="$(_CppWinRTModuleFilterCache)" />
    </ItemGroup>
  </Target>

  <Target Name="PatchXamlTypeInfoActivationIncludes" BeforeTargets="CompileXamlGeneratedFiles" Condition="Exists('$(XamlGeneratedOutputPath)XamlTypeInfo.g.cpp')">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\PatchXamlTypeInfo.ps1&quot; -Path &quot;$(XamlGeneratedOutputPath)XamlTypeInfo.g.cpp&quot;" />
  </Target>

  <Target Name="InvalidateCppWinRTMdMergeWhenMergedWinMDMissing" BeforeTargets="CppWinRTMergeProjectWinMDInputs" Condition="'$(CppWinRTGenerateWindowsMetadata)' == 'true' And !Exists('$(CppWinRTMergedDir)$(RootNamespace).winmd')">
    <Delete Files="$(CppWinRTMdMergeResponseFile)" />
  </Target>

  <Target Name="KeepCppWinRTWinMDOutputs" AfterTargets="CppWinRTCopyWinMDToOutputDirectory" Condition="'$(CppWinRTGenerateWindowsMetadata)' == 'true'">
    <ItemGroup>
      <_IslandsMergedWinMD Include="$(CppWinRTMergedDir)$(RootNamespace).winmd" Condition="Exists('$(CppWinRTMergedDir)$(RootNamespace).winmd')" />
    </ItemGroup>
    <Copy SourceFiles="@(_IslandsMergedWinMD)" DestinationFiles="$(IslandsProjectionWinMD)" SkipUnchangedFiles="false" Condition="'@(_IslandsMergedWinMD)' != ''" />
    <ItemGroup>
      <FileWrites Include="@(_IslandsMergedWinMD)" />
      <FileWrites Include="$(CppWinRTProjectWinMD)" Condition="Exists('$(CppWinRTProjectWinMD)')" />
      <FileWrites Include="$(IslandsProjectionWinMD)" Condition="Exists('$(IslandsProjectionWinMD)')" />
    </ItemGroup>
  </Target>
